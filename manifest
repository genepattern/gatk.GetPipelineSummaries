# GenePattern Module Manifest

LSID=urn:lsid:broad.mit.edu:cancer.software.genepattern.module.generated:37981:1
name=gatk.GetPileupSummaries
version=1
author=GenePattern Team
description=Summarizes counts of reads that support reference, alternate, and other alleles for given sites. Results can be used with CalculateContamination to estimate cross-sample contamination fractions, which are then used to filter somatic variant calls produced by Mutect2. This tool is step 2 in the GATK4 Best Practices somatic variant calling pipeline.
categories=Variant Analysis;Somatic Variant Calling;Quality Control
commandLine=bash <libdir>gatk_getpileupsummaries_wrapper.sh --input.bam <input.bam> --input.bai <input.bai> --variant.vcf <variant.vcf> --variant.vcf.tbi <variant.vcf.tbi> --intervals.file <intervals.file> --intervals.index <intervals.index> --output.file.name <output.file.name> <arguments.file>
cpuType=any
os=any
language=Java
taskType=Java
taskDoc=README.md
quality=development
privacy=public
job.cpuCount=2
job.memory=8Gb
job.docker.image=broadinstitute/gatk\:4.1.4.1
src.repo=https://github.com/broadinstitute/gatk

# Parameters
p1_MODE=IN
p1_TYPE=FILE
p1_description=Coordinate-sorted, indexed BAM, SAM, or CRAM file containing aligned reads. The corresponding index file (BAI) must also be provided. This is passed to GATK as the -I / --input argument.
p1_fileFormat=bam;sam;cram
p1_name=input.bam
p1_numValues=1..1
p1_optional=
p1_type=java.io.File
p2_MODE=IN
p2_TYPE=FILE
p2_description=Index file for the input BAM/CRAM (e.g., .bai for BAM, .crai for CRAM). Must correspond to the input.bam file. The wrapper will stage both the BAM and this index file into the writable working directory so GATK can locate the index alongside the BAM.
p2_fileFormat=bai;crai;csi
p2_name=input.bai
p2_numValues=1..1
p2_optional=
p2_type=java.io.File
p3_MODE=IN
p3_TYPE=FILE
p3_description=bgzipped VCF file containing common germline variant sites annotated with population allele frequencies (AF INFO field). Recommended resources: small_exac_common_3.hg38.vcf.gz or af-only-gnomad.hg38.vcf.gz from the GATK resource bundle. Passed to GATK as the -V / --variant argument. Must match the genome build of the input BAM.
p3_fileFormat=vcf;vcf.gz;bcf
p3_name=variant.vcf
p3_numValues=1..1
p3_optional=
p3_type=java.io.File
p4_MODE=IN
p4_TYPE=FILE
p4_description=Tabix index for the variant VCF file (e.g., .vcf.gz.tbi). Must correspond to the variant.vcf file. The wrapper will stage both the VCF and this index into the writable working directory so GATK can locate the index alongside the VCF.
p4_fileFormat=tbi;idx
p4_name=variant.vcf.tbi
p4_numValues=1..1
p4_optional=
p4_type=java.io.File
p5_MODE=IN
p5_TYPE=FILE
p5_description=Genomic intervals file specifying which sites to include in the pileup. Can be a VCF, BED, Picard interval_list, GATK interval string list (.list), or any other GATK-supported interval format. In standard practice, use the same file as variant.vcf. Passed to GATK as the -L / --intervals argument. This parameter is required even though it is not always listed as such in simplified documentation.
p5_fileFormat=vcf;vcf.gz;bed;list;interval_list
p5_name=intervals.file
p5_numValues=1..1
p5_optional=
p5_type=java.io.File
p6_MODE=IN
p6_TYPE=FILE
p6_description=Index file for the intervals file (e.g., .vcf.gz.tbi if the intervals file is a bgzipped VCF, .idx for uncompressed VCF). Must correspond to the intervals.file. The wrapper will stage both the intervals file and this index into the writable working directory.
p6_fileFormat=tbi;idx
p6_name=intervals.index
p6_numValues=1..1
p6_optional=
p6_type=java.io.File
p7_TYPE=TEXT
p7_default_value=pileup_summary.table
p7_description=Name for the output pileup summary table file. This tab-separated table contains columns: contig, position, ref_count, alt_count, other_alt_count, allele_frequency. The output is used directly as input to GATK CalculateContamination.
p7_name=output.file.name
p7_numValues=1..1
p7_optional=
p7_type=java.lang.String
p8_MODE=IN
p8_TYPE=FILE
p8_description=Optional GATK arguments file containing additional parameters to pass to GetPileupSummaries (one argument or argument=value per line). Use this to specify advanced GATK options such as --tumor-sample, --max-depth-per-sample, --java-options, --tmp-dir, or any other GATK argument not exposed as an explicit module parameter. Passed to GATK as --arguments_file.
p8_fileFormat=txt
p8_name=arguments.file
p8_numValues=0..1
p8_optional=on
p8_prefix_when_specified=--arguments.file 
p8_type=java.io.File

